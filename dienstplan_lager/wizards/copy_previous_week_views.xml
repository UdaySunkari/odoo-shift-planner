<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dienstplan_copy_previous_week_form" model="ir.ui.view">
        <field name="name">dienstplan.copy.previous.week.form</field>
        <field name="model">dienstplan.copy.previous.week</field>
        <field name="arch" type="xml">
            <form string="Copy Previous Week">
                <group>
                    <field name="quell_woche_start"/>
                    <field name="ziel_woche_start"/>
                </group>
                <group>
                    <field name="nur_veroeffentlichte"/>
                    <field name="bestehende_loeschen"/>
                </group>
                <p class="text-muted">
                    All shifts of the source week are duplicated into the
                    target week as drafts. Existing shifts in the target
                    week are kept unless you tick the option above.
                </p>
                <footer>
                    <button name="action_kopieren"
                            type="object"
                            string="Copy"
                            class="btn-primary"/>
                    <button special="cancel"
                            string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
