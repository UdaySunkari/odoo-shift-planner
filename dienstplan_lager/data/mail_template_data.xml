<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_shift_published" model="mail.template">
            <field name="name">Shift Planning: Shift Published</field>
            <field name="model_id" ref="model_dienstplan_schicht"/>
            <field name="subject">Your shift on {{ object.datum_von.strftime('%d.%m.%Y') }} has been confirmed</field>
            <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
            <field name="email_to">{{ object.employee_id.work_email }}</field>
            <field name="body_html" type="html">
<div style="margin:0;padding:0;font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
    <table width="100%" style="max-width:600px;margin:0 auto;background:#ffffff;border-radius:8px;overflow:hidden;border:1px solid #e5e7eb;">
        <tr>
            <td style="background:linear-gradient(135deg,#6366f1,#8b5cf6);padding:24px 30px;">
                <h1 style="color:#fff;margin:0;font-size:20px;">⚡ Shift Confirmed</h1>
            </td>
        </tr>
        <tr>
            <td style="padding:30px;">
                <p style="color:#374151;font-size:15px;margin:0 0 20px;">
                    Hello <strong>{{ object.employee_id.name }}</strong>,
                </p>
                <p style="color:#374151;font-size:15px;margin:0 0 20px;">
                    Your shift has been published and confirmed:
                </p>
                <table style="width:100%;border-collapse:collapse;margin:0 0 24px;">
                    <tr>
                        <td style="padding:10px 14px;background:#f9fafb;border:1px solid #e5e7eb;font-weight:600;color:#6b7280;font-size:13px;width:120px;">Date</td>
                        <td style="padding:10px 14px;background:#f9fafb;border:1px solid #e5e7eb;color:#111827;font-size:14px;">
                            {{ object.datum_von.strftime('%A, %d.%m.%Y') }}
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:10px 14px;border:1px solid #e5e7eb;font-weight:600;color:#6b7280;font-size:13px;">Time</td>
                        <td style="padding:10px 14px;border:1px solid #e5e7eb;color:#111827;font-size:14px;">
                            {{ object.datum_von.strftime('%H:%M') }} – {{ object.datum_bis.strftime('%H:%M') }}
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:10px 14px;background:#f9fafb;border:1px solid #e5e7eb;font-weight:600;color:#6b7280;font-size:13px;">Area</td>
                        <td style="padding:10px 14px;background:#f9fafb;border:1px solid #e5e7eb;color:#111827;font-size:14px;">
                            {{ object.bereich_id.name }}
                        </td>
                    </tr>
                </table>
                <p style="color:#6b7280;font-size:13px;margin:0;">
                    You can view your full schedule at
                    <a href="/dienstplan/my-schedule" style="color:#6366f1;text-decoration:none;font-weight:600;">My Schedule</a>.
                </p>
            </td>
        </tr>
        <tr>
            <td style="background:#f9fafb;padding:16px 30px;border-top:1px solid #e5e7eb;">
                <p style="color:#9ca3af;font-size:12px;margin:0;">
                    This is an automated message from {{ object.company_id.name or 'Shift Planning Turbo' }}.
                </p>
            </td>
        </tr>
    </table>
</div>
            </field>
        </record>

    </data>
</odoo>
