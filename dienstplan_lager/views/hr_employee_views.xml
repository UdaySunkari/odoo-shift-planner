<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_form_inherit_dienstplan" model="ir.ui.view">
        <field name="name">hr.employee.form.dienstplan</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="after">
                <page string="Shift Planning" name="dienstplan">
                    <group>
                        <group>
                            <field name="standard_bereich_id"/>
                            <field name="weekly_hours_target"/>
                        </group>
                        <group>
                            <field name="bereich_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
