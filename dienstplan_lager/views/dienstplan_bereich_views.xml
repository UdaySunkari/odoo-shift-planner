<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dienstplan_bereich_list" model="ir.ui.view">
        <field name="name">dienstplan.bereich.list</field>
        <field name="model">dienstplan.bereich</field>
        <field name="arch" type="xml">
            <list string="Areas" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="html_color"/>
                <field name="color" widget="color_picker"/>
                <field name="ist_abwesenheit"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_dienstplan_bereich_form" model="ir.ui.view">
        <field name="name">dienstplan.bereich.form</field>
        <field name="model">dienstplan.bereich</field>
        <field name="arch" type="xml">
            <form string="Area">
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="ist_abwesenheit"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="html_color" placeholder="#3498db"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="notiz" nolabel="1"
                               placeholder="Optional description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dienstplan_bereich" model="ir.actions.act_window">
        <field name="name">Areas</field>
        <field name="res_model">dienstplan.bereich</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first area
            </p>
            <p>
                Areas are the work zones / roles employees can be scheduled in,
                e.g. "Picking", "Packing", "Reception".
            </p>
        </field>
    </record>

</odoo>