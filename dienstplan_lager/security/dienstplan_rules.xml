<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================
             Multi-company record rules
             ============================================================
             These ensure that in a multi-company Odoo instance, users
             only see the data that belongs to their current company
             (or data shared across all companies where company_id is
             left empty).

             Pattern used:
               Shifts  → always company-bound (company_id is required)
               Areas   → can be global (company_id = False) OR per-company
               Templates → same as areas
        -->

        <!-- Shifts: only see shifts from your own company -->
        <record id="rule_schicht_company" model="ir.rule">
            <field name="name">Shift: multi-company</field>
            <field name="model_id" ref="model_dienstplan_schicht"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Areas: see global areas + your company's areas -->
        <record id="rule_bereich_company" model="ir.rule">
            <field name="name">Area: multi-company</field>
            <field name="model_id" ref="model_dienstplan_bereich"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Templates: see global templates + your company's templates -->
        <record id="rule_vorlage_company" model="ir.rule">
            <field name="name">Template: multi-company</field>
            <field name="model_id" ref="model_dienstplan_schicht_vorlage"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
